# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL (e.g. https://xyzxyzxyz.supabase.co)
SUPABASE_URL=

# Anon / public key — safe to expose to the browser (RLS protects data)
SUPABASE_KEY=

# Service role key — SERVER ONLY. Never expose this to the browser.
# Used by: /api/admin/check and the sitemap generator.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site ─────────────────────────────────────────────────────────────────────
# Your production domain, no trailing slash (e.g. https://bestdeal3z.com)
NUXT_PUBLIC_SITE_URL=

# WhatsApp number in international format WITHOUT + or spaces (e.g. 919000000000)
NUXT_PUBLIC_WHATSAPP_NUMBER=
